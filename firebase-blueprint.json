{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile metadata stored upon registration.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique user ID from Firebase Authentication"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User email address"
        },
        "displayName": {
          "type": "string",
          "description": "User display name"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "Access control role"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user registered"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Educational lesson for traffic laws and driving rules.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": ["rw", "en", "fr"]
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "title", "content", "category", "language"]
    },
    "Question": {
      "title": "Question",
      "description": "Theory driving exam practice question.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "questionText": {
          "type": "string"
        },
        "options": {
          "type": "array"
        },
        "correctAnswerIndex": {
          "type": "number"
        },
        "explanation": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": ["rw", "en", "fr"]
        }
      },
      "required": ["id", "questionText", "correctAnswerIndex", "category", "language"]
    },
    "RoadSign": {
      "title": "RoadSign",
      "description": "Traffic and road signs definition.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": ["regulatory", "warning", "information", "guidance"]
        },
        "imageUrl": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "language": {
          "type": "string",
          "enum": ["rw", "en", "fr"]
        }
      },
      "required": ["id", "title", "category", "language"]
    },
    "ExamSession": {
      "title": "ExamSession",
      "description": "A driving theory mock exam session initiated by a user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "startedAt": {
          "type": "string"
        },
        "endedAt": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "completed": {
          "type": "boolean"
        }
      },
      "required": ["id", "userId", "startedAt", "completed"]
    },
    "ExamResult": {
      "title": "ExamResult",
      "description": "Result record of a completed exam session.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "score": {
          "type": "number"
        },
        "percentage": {
          "type": "number"
        },
        "passed": {
          "type": "boolean"
        },
        "date": {
          "type": "string"
        }
      },
      "required": ["id", "userId", "score", "percentage", "passed", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/lessons/{lessonId}": {
      "schema": { "$ref": "Lesson" },
      "description": "Driving lessons"
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "Question" },
      "description": "Theory exam practice questions"
    },
    "/roadSigns/{signId}": {
      "schema": { "$ref": "RoadSign" },
      "description": "Traffic road signs catalog"
    },
    "/examSessions/{sessionId}": {
      "schema": { "$ref": "ExamSession" },
      "description": "User theory test practice exam sessions"
    },
    "/examResults/{resultId}": {
      "schema": { "$ref": "ExamResult" },
      "description": "User practice exam historical score cards"
    }
  }
}
